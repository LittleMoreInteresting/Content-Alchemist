{
  "$schema": "https://wails.io/schemas/config.v2.json",
  "name": "content-alchemist",
  "outputfilename": "Content-Alchemist",
  "frontend": {
    "dir": "./frontend",
    "install": "npm install",
    "build": "npm run build",
    "package": "npm run build"
  },
  "author": {
    "name": "Content-Alchemist Team",
    "email": "dev@content-alchemist.app"
  },
  "info": {
    "company": "Content-Alchemist",
    "productName": "Content-Alchemist Pro",
    "copyright": "Copyright © 2024",
    "comments": "AI驱动的本地优先写作助手"
  },
  "build": {
    "productName": "Content-Alchemist",
    "appId": "com.contentalchemist.app",
    "asar": true,
    "directories": {
      "output": "build"
    },
    "mac": {
      "target": ["dmg", "zip"]
    },
    "win": {
      "target": ["nsis", "portable"]
    },
    "linux": {
      "target": ["AppImage", "deb"]
    }
  }
}
